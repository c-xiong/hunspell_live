# Copy to .env and adjust.

# Persist anonymous "error -> correction" pairs into data/replacements.db
# (SQLite). Keep false on public instances; enable on self-hosted research
# instances. Export via GET /api/replacements/export/?format=csv|json
ENABLE_REPLACEMENT_LOGGING=false

# Development only: origins allowed to call the API cross-origin (the Vite
# dev server). Production is same-origin and ignores this.
CORS_ORIGINS=http://localhost:5173

# Optional overrides (defaults shown):
# DATA_DIR=./data                 # where replacements.db lives
# UPLOAD_MAX_BYTES=10485760       # .aff + .dic combined upload limit
# UPLOAD_TTL_SECONDS=7200         # session dictionary lifetime
# UPLOAD_MAX_SESSIONS=20          # max concurrently loaded uploads
